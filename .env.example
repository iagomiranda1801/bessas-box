# Loja atual — use o mesmo domínio em VITE_ e SHOPIFY_
VITE_SHOPIFY_STORE_DOMAIN=uvhyj5-ty.myshopify.com
SHOPIFY_STORE_DOMAIN=uvhyj5-ty.myshopify.com

# Token público Headless (canal Headless → Storefront API). NÃO use shpat_ aqui.
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Token privado Headless — catálogo e sacola no servidor
SHOPIFY_STOREFRONT_PRIVATE_TOKEN=

# Token Admin API (opcional, painel futuro)
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Checklist admin (canais, estoque, senha, checkout convidado): docs/SHOPIFY_SETUP.md

# Supabase — projeto Vite (NÃO use NEXT_PUBLIC_)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...ou eyJ...anon
SUPABASE_SERVICE_ROLE_KEY=
